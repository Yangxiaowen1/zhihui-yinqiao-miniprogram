/* 聚合页面 - 统一风格 */
.page-aggregate {
  padding: 24rpx 24rpx 140rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f5f5 0%, #e8e8e8 100%);
}

/* 页面头部 */
.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 12rpx 24rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
}

.role-tag {
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 20rpx;
  font-size: 24rpx;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #999;
}

/* 模块卡片 */
.module-card {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.module-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.module-header:active {
  background: #f9f9f9;
}

.module-left {
  display: flex;
  align-items: center;
}

.module-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.module-info {
  display: flex;
  flex-direction: column;
}

.module-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.module-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.module-arrow {
  font-size: 40rpx;
  color: #ccc;
}

/* 模块预览 */
.module-preview {
  padding: 0 32rpx;
}

.empty-preview {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.preview-list {
  padding: 16rpx 0;
}

/* 预览项通用样式 */
.preview-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.preview-item:last-child {
  border-bottom: none;
}

.preview-item:active {
  background: #fafafa;
}

.preview-content {
  flex: 1;
  min-width: 0;
}

.preview-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.preview-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 8rpx;
}

.preview-teacher,
.preview-field,
.preview-time,
.preview-place {
  font-size: 24rpx;
  color: #999;
}

.preview-right {
  text-align: right;
  margin-left: 16rpx;
}

.preview-count {
  font-size: 26rpx;
  color: #666;
}

.preview-status {
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.status-available {
  background: rgba(76, 175, 80, 0.1);
  color: #4caf50;
}

.status-full {
  background: rgba(255, 152, 0, 0.1);
  color: #ff9800;
}

.status-ended,
.status-cancelled {
  background: rgba(158, 158, 158, 0.1);
  color: #9e9e9e;
}

/* 专家预览项 */
.expert-item .expert-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 500;
  margin-right: 20rpx;
}

.preview-stars {
  color: #ffc107;
  font-size: 24rpx;
}

.preview-rating {
  font-size: 26rpx;
  color: #4caf50;
  font-weight: 500;
}

/* 活动预览项 */
.activity-item {
  position: relative;
}

.activity-type-tag {
  position: absolute;
  top: 24rpx;
  left: 0;
  padding: 4rpx 12rpx;
  background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);
  color: #fff;
  font-size: 20rpx;
  border-radius: 8rpx;
}

.activity-item .preview-content {
  padding-left: 120rpx;
}

/* 查看全部 */
.view-all {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  border-top: 1rpx solid #f0f0f0;
  font-size: 26rpx;
  color: #667eea;
}

.view-all:active {
  background: #fafafa;
}

.view-all .arrow {
  margin-left: 8rpx;
  font-size: 28rpx;
}

/* 无障碍支持 */
@media (prefers-reduced-motion: reduce) {
  .loading-spinner {
    animation: none;
  }
}
