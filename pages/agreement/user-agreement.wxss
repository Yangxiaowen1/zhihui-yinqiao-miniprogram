/* 协议页面通用样式 */
.agreement-page {
  min-height: 100vh;
  background: #fff;
  padding: 40rpx;
}

.agreement-content {
  padding-bottom: 80rpx;
}

.agreement-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 32rpx;
}

.update-time,
.effective-time {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  margin-bottom: 8rpx;
}

.section {
  margin-top: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #4caf50;
}

.section-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.section-content text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}
