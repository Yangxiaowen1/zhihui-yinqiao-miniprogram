/* 智汇银桥 - 简化登录页样式 */
.login-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #4caf50 0%, #66bb6a 50%, #81c784 100%);
  display: flex;
  flex-direction: column;
  padding: 100rpx 40rpx 40rpx;
  position: relative;
  overflow: hidden;
}

/* 装饰图案 */
.login-page::before {
  content: '';
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 400rpx;
  height: 400rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 50%;
}

.login-page::after {
  content: '';
  position: absolute;
  bottom: -150rpx;
  left: -150rpx;
  width: 500rpx;
  height: 500rpx;
  background: rgba(255,255,255,0.08);
  border-radius: 50%;
}

/* ========== 顶部LOGO区域 ========== */
.login-header {
  text-align: center;
  padding: 40rpx 0 60rpx;
  position: relative;
  z-index: 1;
}

.logo-container {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.app-logo {
  font-size: 120rpx;
  margin-bottom: 20rpx;
  display: block;
  filter: drop-shadow(0 4rpx 8rpx rgba(0,0,0,0.2));
}

.app-title {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
  text-shadow: 0 4rpx 12rpx rgba(0,0,0,0.2);
  letter-spacing: 8rpx;
}

.app-slogan {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
  letter-spacing: 2rpx;
}

/* ========== 登录表单卡片 ========== */
.login-form-card {
  background: rgba(255,255,255,0.95);
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.2);
  position: relative;
  z-index: 1;
}

.input-group {
  margin-bottom: 32rpx;
}

.input-label {
  margin-bottom: 16rpx;
}

.label-text {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.input-field {
  width: 100%;
  height: 96rpx;
  background: #f5f5f5;
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  color: #333;
  box-sizing: border-box;
  transition: all 0.3s ease;
}

.input-field:focus {
  border-color: #4caf50;
  background: #fff;
}

.code-input-wrapper {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.code-input {
  flex: 1;
}

.code-btn {
  flex-shrink: 0;
  min-width: 200rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #4caf50, #66bb6a);
  color: #fff;
  border: none;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.code-btn.disabled {
  background: #ccc;
  color: #999;
}

/* 登录按钮 */
.login-btn {
  width: 100%;
  background: linear-gradient(135deg, #4caf50, #66bb6a);
  color: #fff;
  border: none;
  border-radius: 24rpx;
  padding: 36rpx;
  font-size: 34rpx;
  font-weight: bold;
  margin-top: 20rpx;
  box-shadow: 0 6rpx 20rpx rgba(76, 175, 80, 0.4);
  transition: all 0.3s ease;
}

.login-btn:active {
  transform: scale(0.98);
}

/* 微信登录分隔线 */
.wechat-login-divider {
  display: flex;
  align-items: center;
  margin: 40rpx 0 32rpx;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: #e0e0e0;
}

.divider-text {
  padding: 0 24rpx;
  font-size: 26rpx;
  color: #999;
}

/* 微信登录按钮 */
.wechat-btn {
  width: 100%;
  background: #07c160;
  color: #fff;
  border: none;
  border-radius: 24rpx;
  padding: 32rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(7, 193, 96, 0.3);
  transition: all 0.3s ease;
}

.wechat-btn:active {
  transform: scale(0.98);
}

.wechat-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.wechat-text {
  font-size: 32rpx;
  font-weight: bold;
}

/* ========== 协议区域 ========== */
.agreement-section {
  padding: 32rpx 0;
  position: relative;
  z-index: 1;
}

.agreement-check {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 3rpx solid rgba(255,255,255,0.8);
  border-radius: 8rpx;
  margin-right: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.checkbox.checked {
  background: #fff;
  border-color: #fff;
}

.check-icon {
  font-size: 28rpx;
  color: #4caf50;
  font-weight: bold;
}

.agreement-text {
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
}

.agreement-links {
  display: flex;
  align-items: center;
  justify-content: center;
}

.agreement-link {
  font-size: 26rpx;
  color: #fff;
  text-decoration: underline;
  font-weight: 500;
}
