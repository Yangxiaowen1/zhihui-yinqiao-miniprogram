/* 专家巡讲活动页面 - 蓝色主题 */
.page-expert-lecture {
  padding-bottom: 40rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f7ff 0%, #e3f2fd 100%);
}

/* 活动封面 */
.lecture-banner {
  background: linear-gradient(135deg, #1976d2 0%, #2196f3 50%, #42a5f5 100%);
  padding: 80rpx 40rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.lecture-banner::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, transparent 60%);
}

.banner-bg {
  font-size: 140rpx;
  display: block;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.banner-content {
  position: relative;
  z-index: 1;
}

.banner-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
}

.banner-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
  font-style: italic;
}

/* 通用区块 */
.section {
  padding: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1565c0;
  flex: 1;
  position: relative;
  padding-left: 20rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 32rpx;
  background: #2196f3;
  border-radius: 4rpx;
}

.section-badge {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #4caf50, #66bb6a);
  color: #fff;
  border-radius: 20rpx;
  font-weight: 500;
}

.section-badge.badge-soon {
  background: linear-gradient(135deg, #ff9800, #ffa726);
}

/* 当前巡讲卡片 */
.lecture-card {
  background: linear-gradient(135deg, #fff 0%, #f5f5f5 100%);
  border-radius: 24rpx;
  padding: 36rpx;
  box-shadow: 0 6rpx 20rpx rgba(33, 150, 243, 0.15);
  border: 3rpx solid #bbdefb;
  position: relative;
  overflow: hidden;
}

.lecture-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  width: 8rpx;
  height: 100%;
  background: #2196f3;
  border-radius: 24rpx 0 0 24rpx;
}

.lecture-header {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
  position: relative;
  z-index: 1;
}

.expert-avatar {
  font-size: 80rpx;
  background: linear-gradient(135deg, #42a5f5, #2196f3);
  border-radius: 50%;
  width: 120rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(33, 150, 243, 0.3);
  border: 4rpx solid #bbdefb;
}

.expert-info {
  flex: 1;
}

.expert-name {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #1565c0;
  margin-bottom: 8rpx;
}

.expert-title {
  display: block;
  font-size: 28rpx;
  color: #2196f3;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.expert-field {
  display: block;
  font-size: 26rpx;
  color: #546e7a;
}

.lecture-body {
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.info-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.info-label {
  font-size: 28rpx;
  color: #546e7a;
  width: 120rpx;
  flex-shrink: 0;
  font-weight: 500;
}

.info-value {
  font-size: 30rpx;
  color: #333;
  flex: 1;
  font-weight: 500;
}

.lecture-intro {
  background: #e3f2fd;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 20rpx;
}

.intro-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #1565c0;
  margin-bottom: 12rpx;
}

.intro-content {
  display: block;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.btn-join {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #2196f3, #42a5f5);
  color: #fff;
  border-radius: 20rpx;
  font-size: 34rpx;
  font-weight: bold;
  box-shadow: 0 6rpx 20rpx rgba(33, 150, 243, 0.4);
  position: relative;
  z-index: 1;
}

.btn-join:active {
  transform: scale(0.98);
}

.btn-remind {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #fff;
  color: #2196f3;
  border: 3rpx solid #2196f3;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: bold;
  position: relative;
  z-index: 1;
}

/* 往期回顾 */
.history-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.history-item {
  background: linear-gradient(135deg, #fff 0%, #f5f5f5 100%);
  border-radius: 20rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(33, 150, 243, 0.1);
  border: 2rpx solid #bbdefb;
  position: relative;
}

.history-date {
  text-align: center;
  background: #e3f2fd;
  border-radius: 12rpx;
  padding: 12rpx 20rpx;
  margin-right: 24rpx;
}

.date-month {
  display: block;
  font-size: 24rpx;
  color: #2196f3;
  font-weight: 500;
}

.date-day {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #1565c0;
}

.history-content {
  flex: 1;
}

.history-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.history-meta {
  display: block;
  font-size: 26rpx;
  color: #546e7a;
}

.history-status {
  font-size: 24rpx;
  color: #757575;
  background: #f5f5f5;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

/* 服务说明 */
.service-info {
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
  border-radius: 20rpx;
  padding: 32rpx;
  border: 3rpx solid #bbdefb;
}

.info-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #1565c0;
  margin-bottom: 20rpx;
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.info-item {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

/* 适老化设计增强 */
.lecture-card:active,
.history-item:active {
  transform: scale(0.98);
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
  transition: all 0.2s;
}

/* 无障碍支持 */
@media (prefers-reduced-motion: reduce) {
  .lecture-card:active,
  .history-item:active,
  .btn-join:active {
    transform: none;
  }
}
