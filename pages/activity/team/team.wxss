/* 活动组队页面 - 橙色主题 */
.page-team {
  padding: 24rpx 24rpx 80rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #fff8e1 0%, #ffecb3 100%);
}

.card {
  background: linear-gradient(135deg, #fff 0%, #f5f5f5 100%);
  border-radius: 24rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(255, 152, 0, 0.15);
  border: 3rpx solid #ffe0b2;
  position: relative;
  overflow: hidden;
}

.card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  width: 8rpx;
  height: 100%;
  background: #ff9800;
  border-radius: 24rpx 0 0 24rpx;
}

.activity-name {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 16rpx;
  color: #e65100;
  position: relative;
  z-index: 1;
}

.meta {
  font-size: 28rpx;
  color: #ef6c00;
  position: relative;
  z-index: 1;
}

.section {
  margin-bottom: 32rpx;
  position: relative;
  z-index: 1;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #e65100;
  margin-bottom: 20rpx;
  display: block;
  position: relative;
  z-index: 1;
}

.team-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  position: relative;
  z-index: 1;
}

.team-item {
  flex: 1 1 calc(50% - 10rpx);
  background: rgba(255,255,255,0.8);
  border: 2rpx solid #ffb74d;
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
  position: relative;
  z-index: 1;
}

.team-item:active {
  background: #fff3e0;
  transform: scale(0.96);
  transition: all 0.2s;
}

.team-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #e65100;
  margin-bottom: 8rpx;
  display: block;
}

.team-count {
  font-size: 24rpx;
  color: #ef6c00;
}

.empty {
  text-align: center;
  color: #ef6c00;
  font-size: 30rpx;
  padding: 60rpx 24rpx;
  background: #fff3e0;
  border-radius: 16rpx;
  border: 2rpx solid #ffe0b2;
  margin-top: 24rpx;
  position: relative;
  z-index: 1;
}

.btn {
  margin-top: 48rpx;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 20rpx;
  font-size: 34rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #ff9800, #ffa726);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(255, 152, 0, 0.4);
  position: relative;
  z-index: 1;
}
