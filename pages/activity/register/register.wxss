/* 活动报名页面 - 橙色主题 */
.page-register {
  padding: 24rpx 24rpx 80rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #fff8e1 0%, #ffecb3 100%);
}

.card {
  background: linear-gradient(135deg, #fff 0%, #f5f5f5 100%);
  border-radius: 24rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(255, 152, 0, 0.15);
  border: 3rpx solid #ffe0b2;
  position: relative;
  overflow: hidden;
}

.card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  width: 8rpx;
  height: 100%;
  background: #ff9800;
  border-radius: 24rpx 0 0 24rpx;
}

.activity-name {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 16rpx;
  color: #e65100;
  position: relative;
  z-index: 1;
}

.meta {
  font-size: 28rpx;
  color: #ef6c00;
  position: relative;
  z-index: 1;
}

.label {
  font-size: 28rpx;
  color: #ef6c00;
  display: block;
  margin-bottom: 20rpx;
  font-weight: 500;
  position: relative;
  z-index: 1;
}

.input {
  font-size: 30rpx;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #ffb74d;
  width: 100%;
  background: rgba(255,255,255,0.8);
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
  position: relative;
  z-index: 1;
}

.picker {
  font-size: 30rpx;
  color: #333;
  background: rgba(255,255,255,0.8);
  border: 2rpx solid #ffb74d;
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
  position: relative;
  z-index: 1;
}

.tip {
  font-size: 28rpx;
  color: #ef6c00;
  line-height: 1.5;
  background: #fff3e0;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  border: 2rpx solid #ffe0b2;
  display: block;
  position: relative;
  z-index: 1;
}

.btn-primary {
  margin-top: 48rpx;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 20rpx;
  font-size: 34rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #ff9800, #ffa726);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(255, 152, 0, 0.4);
  position: relative;
  z-index: 1;
}
