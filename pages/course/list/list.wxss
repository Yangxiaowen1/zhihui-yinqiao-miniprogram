/* 课程列表页面 - 绿色主题 */
.page-course-list {
  padding: 24rpx 24rpx 80rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f7f0 0%, #e8f5e8 100%);
  position: relative;
}

/* 页面头部 */
.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding: 0 12rpx;
}

.header-left {
  display: flex;
  flex-direction: column;
}

.page-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #2e7d32;
  position: relative;
  padding-left: 20rpx;
}

.page-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 36rpx;
  background: #4caf50;
  border-radius: 4rpx;
}

.page-desc {
  font-size: 26rpx;
  color: #558b2f;
  margin-top: 8rpx;
  padding-left: 20rpx;
}

.role-tag {
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #66bb6a 0%, #43a047 100%);
  color: #fff;
  border-radius: 20rpx;
  font-size: 24rpx;
}

/* 筛选栏 */
.filter-bar {
  margin-bottom: 24rpx;
  position: relative;
  z-index: 10;
}

.filter-tabs {
  display: flex;
  gap: 16rpx;
  padding: 0 8rpx;
  overflow-x: auto;
}

.filter-tab {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 16rpx 24rpx;
  background: #fff;
  border-radius: 28rpx;
  font-size: 26rpx;
  color: #558b2f;
  border: 2rpx solid #c8e6c9;
  white-space: nowrap;
  flex-shrink: 0;
}

.filter-tab.active {
  background: #e8f5e9;
  border-color: #4caf50;
  color: #2e7d32;
  font-weight: 500;
}

.filter-arrow {
  font-size: 18rpx;
  color: #81c784;
}

.filter-panel {
  background: #fff;
  border-radius: 0 0 20rpx 20rpx;
  padding: 20rpx;
  margin-top: 8rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  border: 2rpx solid #c8e6c9;
}

.filter-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.filter-option {
  padding: 14rpx 28rpx;
  background: #f5f5f5;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #666;
}

.filter-option.selected {
  background: #4caf50;
  color: #fff;
}

.filter-reset {
  text-align: center;
  padding: 16rpx;
  margin-top: 16rpx;
  color: #999;
  font-size: 26rpx;
  border-top: 1rpx solid #f0f0f0;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #4caf50;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.loading-spinner.small {
  width: 40rpx;
  height: 40rpx;
  border-width: 3rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #999;
}

/* 空状态 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #558b2f;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
}

/* 课程列表 */
.list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.course-card {
  background: linear-gradient(135deg, #fff 0%, #f5f5f5 100%);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 20rpx rgba(76, 175, 80, 0.15);
  border: 3rpx solid #a5d6a7;
  position: relative;
}

.course-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  width: 8rpx;
  height: 100%;
  background: #4caf50;
  border-radius: 24rpx 0 0 24rpx;
}

.card-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 16rpx;
}

.card-main:active {
  background: rgba(76, 175, 80, 0.05);
}

.card-left {
  flex: 1;
  min-width: 0;
}

.course-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #2e7d32;
  margin-bottom: 12rpx;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.course-meta {
  display: flex;
  gap: 20rpx;
  margin-bottom: 12rpx;
}

.course-teacher,
.course-time {
  font-size: 24rpx;
  color: #558b2f;
}

.course-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.course-tag {
  font-size: 22rpx;
  color: #4caf50;
  background: #e8f5e8;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

.course-tag.age-tag {
  color: #ff9800;
  background: #fff3e0;
}

.course-count {
  font-size: 24rpx;
  color: #81c784;
}

.card-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  margin-left: 16rpx;
}

.status {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

.status-available {
  background: #e8f5e9;
  color: #2e7d32;
  border: 2rpx solid #81c784;
}

.status-full {
  background: #fff3e0;
  color: #ef6c00;
  border: 2rpx solid #ffb74d;
}

.status-ended {
  background: #f5f5f5;
  color: #757575;
  border: 2rpx solid #bdbdbd;
}

.status-cancelled {
  background: #ffebee;
  color: #c62828;
  border: 2rpx solid #ef9a9a;
}

.remaining {
  font-size: 22rpx;
  color: #ff5722;
  margin-top: 8rpx;
  font-weight: 500;
}

/* 卡片底部操作栏 */
.card-actions {
  display: flex;
  justify-content: flex-end;
  padding: 8rpx 32rpx 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.fav-btn {
  padding: 8rpx 16rpx;
  font-size: 28rpx;
}

.fav-active {
  transform: scale(1.1);
}

/* 加载更多 */
.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
  gap: 16rpx;
}

.no-more {
  text-align: center;
  padding: 40rpx 0;
  font-size: 24rpx;
  color: #999;
}

/* 无障碍支持 */
@media (prefers-reduced-motion: reduce) {
  .loading-spinner {
    animation: none;
  }
  .fav-active {
    transform: none;
  }
}
