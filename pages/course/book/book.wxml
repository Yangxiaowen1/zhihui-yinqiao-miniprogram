<view class="page-book">
  <view class="card">
    <text class="course-name">{{courseName}}</text>
    <text class="meta">时间：{{time}} · 地点：{{place}}</text>
  </view>
  <view class="card">
    <text class="label">预约人姓名</text>
    <input class="input" placeholder="请输入姓名" value="{{name}}" bindinput="onNameInput" />
  </view>
  <view class="card">
    <text class="label">联系电话</text>
    <input class="input" type="number" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" />
  </view>
  <view class="card">
    <text class="label">备注（选填）</text>
    <textarea class="textarea" placeholder="如：带一名儿童参加" value="{{remark}}" bindinput="onRemarkInput" />
  </view>
  <button class="btn btn-primary" bindtap="submit">提交预约</button>
</view>
