/* 课程扫描页面 - 绿色主题 */
.page-scan {
  padding: 48rpx;
  text-align: center;
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f7f0 0%, #e8f5e8 100%);
}

.tip {
  font-size: 30rpx;
  color: #558b2f;
  margin-bottom: 48rpx;
  font-weight: 500;
}

.scan-area {
  margin: 48rpx 0;
  padding: 48rpx;
  background: linear-gradient(135deg, #fff 0%, #f5f5f5 100%);
  border-radius: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(76, 175, 80, 0.15);
  border: 3rpx solid #a5d6a7;
}

.scan-btn {
  display: inline-block;
  padding: 32rpx 64rpx;
  background: linear-gradient(135deg, #4caf50, #66bb6a);
  color: #fff;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 6rpx 20rpx rgba(76, 175, 80, 0.4);
  transition: all 0.3s ease;
}

.scan-btn:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 16rpx rgba(76, 175, 80, 0.5);
}

.course-info {
  font-size: 28rpx;
  color: #558b2f;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  align-items: center;
  padding: 32rpx;
  background: linear-gradient(135deg, #e8f5e8 0%, #c8e6c9 100%);
  border-radius: 16rpx;
  border: 2rpx solid #a5d6a7;
  margin-top: 32rpx;
}

/* 无障碍支持 */
@media (prefers-reduced-motion: reduce) {
  .scan-btn:active {
    transform: none;
  }
}
