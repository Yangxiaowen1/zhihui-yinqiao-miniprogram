/* 课程评价页面 - 绿色主题 */
.page-evaluate {
  padding: 24rpx 24rpx 80rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f7f0 0%, #e8f5e8 100%);
}

.card {
  background: linear-gradient(135deg, #fff 0%, #f5f5f5 100%);
  border-radius: 24rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(76, 175, 80, 0.15);
  border: 3rpx solid #a5d6a7;
  position: relative;
  overflow: hidden;
}

.card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  width: 8rpx;
  height: 100%;
  background: #4caf50;
  border-radius: 24rpx 0 0 24rpx;
}

.course-name {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 24rpx;
  color: #2e7d32;
  position: relative;
  z-index: 1;
}

.label {
  font-size: 28rpx;
  color: #558b2f;
  display: block;
  margin: 24rpx 0 16rpx;
  font-weight: 500;
  position: relative;
  z-index: 1;
}

.stars {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.star {
  font-size: 60rpx;
  color: #ddd;
  transition: all 0.2s ease;
}

.star.on {
  color: #4caf50;
  transform: scale(1.1);
}

.textarea {
  width: 100%;
  min-height: 160rpx;
  font-size: 30rpx;
  padding: 24rpx;
  border: 3rpx solid #a5d6a7;
  border-radius: 16rpx;
  margin-top: 16rpx;
  background: rgba(255,255,255,0.8);
  position: relative;
  z-index: 1;
}

.btn {
  margin-top: 48rpx;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 20rpx;
  font-size: 34rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #4caf50, #66bb6a);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(76, 175, 80, 0.4);
  position: relative;
  z-index: 1;
}
