/* 搜索页面 - 蓝色主题 */
.page-search {
  padding: 24rpx 24rpx 80rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f7ff 0%, #e3f2fd 100%);
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.input {
  flex: 1;
  height: 72rpx;
  background: linear-gradient(135deg, #fff 0%, #f5f5f5 100%);
  border-radius: 36rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  border: 2rpx solid #bbdefb;
  box-shadow: 0 4rpx 12rpx rgba(33, 150, 243, 0.1);
}

.btn-cancel {
  font-size: 30rpx;
  color: #2196f3;
  font-weight: 500;
}

.tabs {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
  flex-wrap: wrap;
}

.tab {
  padding: 16rpx 28rpx;
  background: linear-gradient(135deg, #fff 0%, #f5f5f5 100%);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #546e7a;
  border: 2rpx solid #bbdefb;
  box-shadow: 0 4rpx 12rpx rgba(33, 150, 243, 0.1);
  transition: all 0.3s ease;
}

.tab.on {
  background: linear-gradient(135deg, #2196f3, #42a5f5);
  color: #fff;
  border-color: #2196f3;
  font-weight: 500;
}

.result {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.item {
  background: linear-gradient(135deg, #fff 0%, #f5f5f5 100%);
  border-radius: 24rpx;
  padding: 36rpx;
  box-shadow: 0 6rpx 20rpx rgba(33, 150, 243, 0.15);
  border: 3rpx solid #bbdefb;
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  width: 8rpx;
  height: 100%;
  background: #2196f3;
  border-radius: 24rpx 0 0 24rpx;
}

.item .name {
  font-size: 34rpx;
  font-weight: bold;
  display: block;
  color: #1565c0;
  margin-bottom: 12rpx;
  position: relative;
  z-index: 1;
}

.item .sub {
  font-size: 28rpx;
  color: #546e7a;
  margin-top: 8rpx;
  position: relative;
  z-index: 1;
}

.empty {
  text-align: center;
  color: #546e7a;
  padding: 100rpx 24rpx;
  font-size: 32rpx;
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
  border-radius: 24rpx;
  border: 3rpx solid #bbdefb;
  margin-top: 40rpx;
}

/* 适老化设计增强 */
.item:active {
  transform: scale(0.98);
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
}

/* 无障碍支持 */
@media (prefers-reduced-motion: reduce) {
  .item:active {
    transform: none;
  }
}
