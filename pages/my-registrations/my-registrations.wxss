/* 我的报名页面 - 紫色主题 */
.page-my-reg {
  padding: 24rpx 24rpx 80rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #f3e5f5 0%, #e1bee7 100%);
}

.tabs {
  display: flex;
  background: linear-gradient(135deg, #fff 0%, #f5f5f5 100%);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 20rpx rgba(156, 39, 176, 0.15);
  border: 3rpx solid #ce93d8;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 28rpx;
  font-size: 30rpx;
  color: #7b1fa2;
  font-weight: 500;
  transition: all 0.3s ease;
}

.tab.on {
  background: linear-gradient(135deg, #9c27b0, #ba68c8);
  color: #fff;
  font-weight: bold;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.card {
  background: linear-gradient(135deg, #fff 0%, #f5f5f5 100%);
  border-radius: 24rpx;
  padding: 36rpx;
  box-shadow: 0 6rpx 20rpx rgba(156, 39, 176, 0.15);
  border: 3rpx solid #ce93d8;
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  width: 8rpx;
  height: 100%;
  background: #9c27b0;
  border-radius: 24rpx 0 0 24rpx;
}

.card .title {
  font-size: 34rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 16rpx;
  color: #6a1b9a;
  position: relative;
  z-index: 1;
}

.card .meta {
  font-size: 28rpx;
  color: #7b1fa2;
  position: relative;
  z-index: 1;
}

/* 适老化设计增强 */
.card:active {
  transform: scale(0.98);
  background: linear-gradient(135deg, #f3e5f5 0%, #e1bee7 100%);
}

/* 无障碍支持 */
@media (prefers-reduced-motion: reduce) {
  .card:active {
    transform: none;
  }
}
