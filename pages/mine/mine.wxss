/* 我的页面 */
.page-mine {
  padding: 24rpx 24rpx 140rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #f3e5f5 0%, #e1bee7 100%);
}

/* 用户信息卡片 */
.user-card {
  background: linear-gradient(135deg, #fff 0%, #f5f5f5 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(156, 39, 176, 0.15);
  border: 3rpx solid #ce93d8;
}

.user-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar-wrapper {
  position: relative;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #e1bee7;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #9c27b0, #ba68c8);
}

.avatar-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
}

.role-badge {
  position: absolute;
  bottom: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  color: #fff;
  white-space: nowrap;
}

.role-badge.parent {
  background: #4caf50;
}

.role-badge.expert {
  background: #ff9800;
}

.role-badge.volunteer {
  background: #2196f3;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.user-phone {
  font-size: 26rpx;
  color: #666;
}

.user-community {
  font-size: 24rpx;
  color: #999;
}

.edit-arrow {
  font-size: 40rpx;
  color: #ccc;
}

/* 角色特定信息 */
.role-info {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #f0f0f0;
  display: flex;
  gap: 40rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.info-label {
  font-size: 24rpx;
  color: #999;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 银龄模式切换卡片 */
.card.silver-mode-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 40rpx;
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
  border-color: #a5d6a7;
  position: relative;
  box-shadow: 0 6rpx 20rpx rgba(76, 175, 80, 0.15);
  overflow: hidden;
}

.card.silver-mode-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  width: 8rpx;
  height: 100%;
  background: #4caf50;
}

.silver-mode-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  flex: 1;
}

.silver-mode-icon {
  font-size: 48rpx;
  font-weight: bold;
  color: #4caf50;
}

.silver-mode-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.silver-mode-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2e7d32;
}

.silver-mode-desc {
  font-size: 26rpx;
  color: #689f38;
}

.silver-switch {
  transform: scale(1.2);
}

/* 菜单卡片 */
.menu-card {
  background: linear-gradient(135deg, #fff 0%, #f5f5f5 100%);
  border-radius: 24rpx;
  padding: 16rpx 40rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(156, 39, 176, 0.15);
  border: 3rpx solid #ce93d8;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 2rpx solid #f3e5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  font-weight: bold;
  color: #9c27b0;
  width: 60rpx;
}

.menu-text {
  flex: 1;
  font-size: 32rpx;
  color: #333;
}

.menu-arrow {
  font-size: 36rpx;
  color: #ccc;
}

.menu-item:active {
  background: #f3e5f5;
  border-radius: 12rpx;
  margin: 0 -24rpx;
  padding: 28rpx 24rpx;
}

/* 银龄模式下的样式增强 */
.page-mine.silver-mode .user-name {
  font-size: 44rpx;
}

.page-mine.silver-mode .user-phone,
.page-mine.silver-mode .user-community {
  font-size: 32rpx;
}

.page-mine.silver-mode .menu-text {
  font-size: 40rpx;
}

.page-mine.silver-mode .silver-mode-title {
  font-size: 40rpx;
}

.page-mine.silver-mode .silver-mode-desc {
  font-size: 32rpx;
}

.page-mine.silver-mode .silver-switch {
  transform: scale(1.4);
}
