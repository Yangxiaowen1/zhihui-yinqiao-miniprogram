/* 专家预约页面 - 蓝色主题 */
.page-book {
  padding: 24rpx 24rpx 80rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f7ff 0%, #e3f2fd 100%);
}

.card {
  background: linear-gradient(135deg, #fff 0%, #f5f5f5 100%);
  border-radius: 24rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(33, 150, 243, 0.15);
  border: 3rpx solid #bbdefb;
  position: relative;
  overflow: hidden;
}

.card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  width: 8rpx;
  height: 100%;
  background: #2196f3;
  border-radius: 24rpx 0 0 24rpx;
}

.expert-name {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 16rpx;
  color: #1565c0;
  position: relative;
  z-index: 1;
}

.slot {
  font-size: 28rpx;
  color: #546e7a;
  position: relative;
  z-index: 1;
}

.label {
  font-size: 28rpx;
  color: #546e7a;
  display: block;
  margin-bottom: 20rpx;
  font-weight: 500;
  position: relative;
  z-index: 1;
}

.input, .textarea {
  font-size: 30rpx;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #64b5f6;
  width: 100%;
  background: rgba(255,255,255,0.8);
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
  position: relative;
  z-index: 1;
}

.textarea {
  min-height: 160rpx;
  border: 2rpx solid #64b5f6;
}

.btn {
  margin-top: 48rpx;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 20rpx;
  font-size: 34rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #2196f3, #42a5f5);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(33, 150, 243, 0.4);
  position: relative;
  z-index: 1;
}
