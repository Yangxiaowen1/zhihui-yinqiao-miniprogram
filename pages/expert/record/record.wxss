/* 专家记录页面 - 蓝色主题 */
.page-record {
  padding: 24rpx 24rpx 80rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f7ff 0%, #e3f2fd 100%);
}

.page-desc {
  font-size: 28rpx;
  color: #546e7a;
  margin-bottom: 24rpx;
  font-weight: 500;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.card {
  background: linear-gradient(135deg, #fff 0%, #f5f5f5 100%);
  border-radius: 24rpx;
  padding: 36rpx;
  box-shadow: 0 6rpx 20rpx rgba(33, 150, 243, 0.15);
  border: 3rpx solid #bbdefb;
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  width: 8rpx;
  height: 100%;
  background: #2196f3;
  border-radius: 24rpx 0 0 24rpx;
}

.row {
  display: flex;
  margin-bottom: 16rpx;
  position: relative;
  z-index: 1;
}

.row:last-child {
  margin-bottom: 0;
}

.label {
  width: 180rpx;
  flex-shrink: 0;
  font-size: 28rpx;
  color: #546e7a;
  font-weight: 500;
}

.value {
  font-size: 30rpx;
  color: #333;
  flex: 1;
  line-height: 1.5;
}

.value.result {
  color: #1565c0;
  line-height: 1.5;
  font-weight: 500;
  background: #e3f2fd;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
  border: 2rpx solid #64b5f6;
}

.empty {
  text-align: center;
  color: #546e7a;
  padding: 100rpx 24rpx;
  font-size: 32rpx;
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
  border-radius: 24rpx;
  border: 3rpx solid #bbdefb;
  margin-top: 40rpx;
}

/* 适老化设计增强 */
.card:active {
  transform: scale(0.98);
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
}

/* 无障碍支持 */
@media (prefers-reduced-motion: reduce) {
  .card:active {
    transform: none;
  }
}
