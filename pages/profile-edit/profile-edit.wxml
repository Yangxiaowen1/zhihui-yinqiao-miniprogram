<!-- 编辑资料页面 -->
<view class="profile-page">
  <view class="page-header">
    <text class="header-title">编辑资料</text>
    <text class="header-subtitle">完善您的个人信息</text>
  </view>

  <!-- 头像 -->
  <view class="avatar-section" bindtap="chooseAvatar">
    <image wx:if="{{userInfo.avatarUrl}}" class="avatar-img" src="{{userInfo.avatarUrl}}" mode="aspectFill"/>
    <view wx:else class="avatar-img avatar-placeholder">
      <text class="avatar-placeholder-text">{{userInfo.nickName ? userInfo.nickName[0] : 'User'}}</text>
    </view>
    <text class="avatar-tip">点击更换头像</text>
  </view>

  <view class="form-container">
    <!-- 公共字段 -->
    <view class="form-item">
      <text class="label">昵称</text>
      <input class="input" placeholder="请输入昵称" value="{{userInfo.nickName}}" bindinput="onNickNameInput"/>
    </view>

    <view class="form-item">
      <text class="label">手机号</text>
      <input class="input" type="number" value="{{userInfo.phone}}" disabled/>
    </view>

    <view class="form-item">
      <text class="label">所在社区</text>
      <picker class="picker" mode="selector" range="{{communities}}" value="{{communityIndex}}" bindchange="onCommunityChange">
        <view class="picker-content">
          <text class="picker-text">{{userInfo.community || '请选择所在社区'}}</text>
          <text class="picker-arrow">></text>
        </view>
      </picker>
    </view>

    <!-- 家长特有字段 -->
    <block wx:if="{{userInfo.role === 'parent'}}">
      <view class="section-title">家长信息</view>
      <view class="form-item">
        <text class="label">家长姓名</text>
        <input class="input" placeholder="请输入姓名" value="{{userInfo.guardianName}}" bindinput="onGuardianNameInput"/>
      </view>
      
      <view class="section-title">孩子信息</view>
      <view class="form-item">
        <text class="label">孩子姓名</text>
        <input class="input" placeholder="请输入孩子姓名" value="{{userInfo.child.name}}" bindinput="onChildNameInput"/>
      </view>
      <view class="form-item">
        <text class="label">孩子年龄</text>
        <picker class="picker" mode="selector" range="{{ageRange}}" value="{{childAgeIndex}}" bindchange="onAgeChange">
          <view class="picker-content">
            <text class="picker-text">{{userInfo.child.age ? userInfo.child.age + '岁' : '请选择年龄'}}</text>
            <text class="picker-arrow">></text>
          </view>
        </picker>
      </view>
      <view class="form-item">
        <text class="label">孩子性别</text>
        <view class="gender-group">
          <view class="gender-option {{userInfo.child.gender === 'male' ? 'active' : ''}}" bindtap="selectChildGender" data-gender="male">
            <text class="gender-text">男</text>
          </view>
          <view class="gender-option {{userInfo.child.gender === 'female' ? 'active' : ''}}" bindtap="selectChildGender" data-gender="female">
            <text class="gender-text">女</text>
          </view>
        </view>
      </view>
    </block>

    <!-- 银龄导师特有字段 -->
    <block wx:if="{{userInfo.role === 'expert'}}">
      <view class="section-title">导师信息</view>
      <view class="form-item">
        <text class="label">姓名</text>
        <input class="input" placeholder="请输入姓名" value="{{userInfo.name}}" bindinput="onNameInput"/>
      </view>
      <view class="form-item">
        <text class="label">年龄</text>
        <picker class="picker" mode="selector" range="{{expertAgeRange}}" value="{{expertAgeIndex}}" bindchange="onExpertAgeChange">
          <view class="picker-content">
            <text class="picker-text">{{userInfo.age ? userInfo.age + '岁' : '请选择年龄'}}</text>
            <text class="picker-arrow">></text>
          </view>
        </picker>
      </view>
      <view class="form-item">
        <text class="label">专业领域</text>
        <picker class="picker" mode="selector" range="{{expertiseOptions}}" value="{{expertiseIndex}}" bindchange="onExpertiseChange">
          <view class="picker-content">
            <text class="picker-text">{{userInfo.expertise || '请选择专业领域'}}</text>
            <text class="picker-arrow">></text>
          </view>
        </picker>
      </view>
      <view class="form-item">
        <text class="label">可服务时间</text>
        <view class="time-options">
          <view class="time-option {{availableTimes.morning ? 'active' : ''}}" bindtap="toggleTime" data-time="morning">
            <text class="time-text">上午</text>
          </view>
          <view class="time-option {{availableTimes.afternoon ? 'active' : ''}}" bindtap="toggleTime" data-time="afternoon">
            <text class="time-text">下午</text>
          </view>
          <view class="time-option {{availableTimes.evening ? 'active' : ''}}" bindtap="toggleTime" data-time="evening">
            <text class="time-text">晚上</text>
          </view>
          <view class="time-option {{availableTimes.weekend ? 'active' : ''}}" bindtap="toggleTime" data-time="weekend">
            <text class="time-text">周末</text>
          </view>
        </view>
      </view>
    </block>

    <!-- 青年志愿者特有字段 -->
    <block wx:if="{{userInfo.role === 'volunteer'}}">
      <view class="section-title">志愿者信息</view>
      <view class="form-item">
        <text class="label">姓名</text>
        <input class="input" placeholder="请输入姓名" value="{{userInfo.name}}" bindinput="onNameInput"/>
      </view>
      <view class="form-item">
        <text class="label">所在院校</text>
        <input class="input" placeholder="请输入学校名称" value="{{userInfo.school}}" bindinput="onSchoolInput"/>
      </view>
      <view class="form-item">
        <text class="label">可服务时间</text>
        <view class="time-options">
          <view class="time-option {{availableTimes.morning ? 'active' : ''}}" bindtap="toggleTime" data-time="morning">
            <text class="time-text">上午</text>
          </view>
          <view class="time-option {{availableTimes.afternoon ? 'active' : ''}}" bindtap="toggleTime" data-time="afternoon">
            <text class="time-text">下午</text>
          </view>
          <view class="time-option {{availableTimes.evening ? 'active' : ''}}" bindtap="toggleTime" data-time="evening">
            <text class="time-text">晚上</text>
          </view>
          <view class="time-option {{availableTimes.weekend ? 'active' : ''}}" bindtap="toggleTime" data-time="weekend">
            <text class="time-text">周末</text>
          </view>
        </view>
      </view>
    </block>

    <!-- 保存按钮 -->
    <button class="save-btn" bindtap="saveProfile">保存修改</button>
  </view>
</view>
