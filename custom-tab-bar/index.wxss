.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 130rpx;
  background: var(--card-bg);
  display: flex;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.1);
  z-index: 999;
  border-top: 3rpx solid var(--border);
}
.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: var(--text-secondary);
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.3s ease;
}
.tab-item .icon { 
  font-size: 52rpx; 
  margin-bottom: 8rpx;
  transition: all 0.3s ease;
}
.tab-item.active {
  color: var(--primary);
  font-weight: bold;
  transform: translateY(-4rpx);
}
.tab-item.active .icon {
  font-size: 56rpx;
  transform: scale(1.1);
}
.tab-item:active {
  background: var(--primary-light);
  border-radius: 20rpx;
  margin: 8rpx;
  transform: scale(0.96);
}

/* 银龄模式下的TabBar样式 */
.tab-bar.silver-mode {
  height: 160rpx;
}

.tab-bar.silver-mode .tab-item {
  font-size: 36rpx;
}

.tab-bar.silver-mode .tab-item .icon {
  font-size: 68rpx;
  margin-bottom: 12rpx;
}

.tab-bar.silver-mode .tab-item.active .icon {
  font-size: 72rpx;
}
