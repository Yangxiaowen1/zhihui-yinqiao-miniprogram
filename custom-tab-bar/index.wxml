<view class="tab-bar {{silverMode ? 'silver-mode' : ''}}">
  <block wx:for="{{list}}" wx:key="pagePath">
    <view
      class="tab-item {{selected === index ? 'active' : ''}}"
      data-index="{{index}}"
      bindtap="switchTab"
    >
      <text class="icon">{{item.icon}}</text>
      <text class="text">{{item.text}}</text>
    </view>
  </block>
</view>
